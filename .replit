modules = ["nodejs-20", "web", "bash", "python-base-3.13"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PDF Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "PDF Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run pdf-server"
waitForPort = 3001

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[userenv]

[userenv.shared]
VITE_PDF_WORKER_URL = ""
VITE_CV_ENGINE_URL = "/cf-engine"
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD = "1"
VITE_GOOGLE_CLIENT_ID = "416398275935-vgsbibc9o6mbpufgfaptoj9jntbet2mj.apps.googleusercontent.com"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "NODE_ENV=production PORT=5000 node backend/server-pdf.cjs"]
build = ["npm", "run", "build"]
publicDir = "dist"
